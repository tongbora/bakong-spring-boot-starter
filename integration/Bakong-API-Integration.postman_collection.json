{
  "info": {
    "name": "Bakong API Integration",
    "_postman_id": "bakong-api-integration-collection",
    "description": "Postman collection for testing Bakong API Integration with Spring Boot.\n\nFlow:\n1. Call **Generate QR** to get the QR string and MD5\n2. Call **Get QR Image** with the QR string to get a scannable image\n3. Call **Check Transaction** with the MD5 to verify payment status\n\nresponseCode == 0 → Payment successful\nresponseCode == 1 → Payment not found / not yet paid",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "qrString",
      "value": "",
      "type": "string",
      "description": "Auto-filled after calling Generate QR"
    },
    {
      "key": "md5",
      "value": "",
      "type": "string",
      "description": "Auto-filled after calling Generate QR"
    }
  ],
  "item": [
    {
      "name": "Step 1 - Generate QR",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "",
              "if (res.data && res.data.qr) {",
              "    pm.collectionVariables.set('qrString', res.data.qr);",
              "    console.log('✅ QR string saved to collection variable');",
              "}",
              "",
              "if (res.data && res.data.md5) {",
              "    pm.collectionVariables.set('md5', res.data.md5);",
              "    console.log('✅ MD5 saved to collection variable:', res.data.md5);",
              "}",
              "",
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('KHQR code is 0 (success)', () => {",
              "    pm.expect(res.KHQRStatus.code).to.eql(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"amount\": 0.1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/bakong/generate-qr",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "bakong", "generate-qr"]
        },
        "description": "Generates a KHQR string and MD5 hash from the given amount.\n\nThe QR string and MD5 are automatically saved to collection variables for use in the next steps."
      },
      "response": [
        {
          "name": "Success",
          "originalRequest": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"amount\": 0.1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/bakong/generate-qr"
            }
          },
          "status": "OK",
          "code": 200,
          "body": "{\n    \"KHQRStatus\": {\n        \"code\": 0,\n        \"errorCode\": null,\n        \"message\": null\n    },\n    \"data\": {\n        \"md5\": \"2e8787edaddc31ffe9c572923db06d33\",\n        \"qr\": \"0002010102121511KH123456789...\"\n    }\n}"
        }
      ]
    },
    {
      "name": "Step 2 - Get QR Image",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is PNG image', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('image/png');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"qr\": \"{{qrString}}\",\n    \"md5\": \"{{md5}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/bakong/get-qr-image",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "bakong", "get-qr-image"]
        },
        "description": "Returns a scannable PNG QR code image.\n\nThe QR string is automatically filled from the Generate QR step.\n\nThe response will be displayed as an image in Postman — scan it with the Bakong app to make a payment."
      },
      "response": [
        {
          "name": "Success - PNG Image",
          "originalRequest": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"qr\": \"{{qrString}}\",\n    \"md5\": \"{{md5}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/bakong/get-qr-image"
            }
          },
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "image/png"
            },
            {
              "key": "Content-Disposition",
              "value": "inline; filename=\"qrcode.png\""
            }
          ],
          "body": ""
        }
      ]
    },
    {
      "name": "Step 3 - Check Transaction",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "",
              "const res = pm.response.json();",
              "",
              "pm.test('Response has responseCode', () => {",
              "    pm.expect(res).to.have.property('responseCode');",
              "});",
              "",
              "if (res.responseCode === 0) {",
              "    console.log('✅ Payment SUCCESS');",
              "    console.log('From:', res.data.fromAccountId);",
              "    console.log('To:', res.data.toAccountId);",
              "    console.log('Amount:', res.data.amount, res.data.currency);",
              "} else {",
              "    console.log('❌ Payment NOT found or not yet paid');",
              "    console.log('Message:', res.responseMessage);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"md5\": \"{{md5}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/bakong/check-transaction",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "bakong", "check-transaction"]
        },
        "description": "Checks whether a transaction has been completed using the MD5 hash.\n\nThe MD5 is automatically filled from the Generate QR step.\n\n**responseCode == 0** → Payment successful ✅\n**responseCode == 1** → Payment not found or not yet paid ❌\n\nNote: In production, this endpoint can only be called from servers located in Cambodia."
      },
      "response": [
        {
          "name": "Payment Successful (responseCode: 0)",
          "originalRequest": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"md5\": \"{{md5}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/bakong/check-transaction"
            }
          },
          "status": "OK",
          "code": 200,
          "body": "{\n    \"responseCode\": 0,\n    \"responseMessage\": \"Success\",\n    \"data\": {\n        \"hash\": \"bf917e9534cac3595ee5dc5a9e7d3b120b6143ff3b368c244189cf22ed9af877\",\n        \"fromAccountId\": \"customer@bank\",\n        \"toAccountId\": \"bora_tong@aclb\",\n        \"currency\": \"USD\",\n        \"amount\": 0.1,\n        \"description\": null,\n        \"createdDateMs\": 1772125349000,\n        \"acknowledgedDateMs\": 1772125351000,\n        \"externalRef\": \"100FT36931627892\"\n    }\n}"
        },
        {
          "name": "Payment Not Found (responseCode: 1)",
          "originalRequest": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n    \"md5\": \"{{md5}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/bakong/check-transaction"
            }
          },
          "status": "OK",
          "code": 200,
          "body": "{\n    \"responseCode\": 1,\n    \"responseMessage\": \"Transaction could not be found. Please check and try again.\",\n    \"errorCode\": 1,\n    \"data\": null\n}"
        }
      ]
    }
  ]
}
